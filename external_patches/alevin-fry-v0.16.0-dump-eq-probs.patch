diff --git a/src/utils.rs b/src/utils.rs
index ac4a4df..f07a79a 100644
--- a/src/utils.rs
+++ b/src/utils.rs
@@ -146,6 +146,26 @@ impl<T: Clone + Copy> ProbMap<T> {
         debug_assert_eq!(self.stride, p.len());
         self.probs.extend_from_slice(p);
     }
+
+    #[inline(always)]
+    pub fn num_rows(&self) -> usize {
+        if self.stride == 0 {
+            0
+        } else {
+            self.probs.len() / self.stride
+        }
+    }
+
+    #[inline(always)]
+    pub fn row(&self, i: usize) -> Option<&[T]> {
+        let s = i * self.stride;
+        let e = s + self.stride;
+        if e <= self.probs.len() {
+            Some(&self.probs[s..e])
+        } else {
+            None
+        }
+    }
 }

